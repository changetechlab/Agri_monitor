# =============================================================
# Agri Monitor — CHANGE TechLab
# Environment Variables Template
# Copy this file to .env and fill in your values.
# For HTML/static deployment, set these in js/config.js
# =============================================================

# --- SUPABASE ---
# Create project at https://supabase.com (free tier available)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here

# --- NDVI / SATELLITE TILES ---
# Option 1: Google Earth Engine tile server (requires GEE setup)
GEE_TILE_URL=https://earthengine.googleapis.com/v1/projects/your-project/maps/{mapId}/tiles/{z}/{x}/{y}
GEE_API_KEY=your-google-cloud-api-key

# Option 2: TiTiler self-hosted (recommended for production)
TITILER_URL=https://your-titiler-instance.com

# Option 3: EOX Sentinel-2 Cloudless (free, no key needed)
# NDVI_TILE_URL=https://tiles.maps.eox.at/wmts/1.0.0/s2cloudless-2020_3857/default/g/{z}/{y}/{x}.jpg

# --- OPTIONAL: Open Weather Map ---
OPENWEATHER_API_KEY=your-openweather-api-key
# Used for rainfall, temperature, frost alerts

# --- APP CONFIG ---
APP_ENV=production
APP_VERSION=1.0.0
PILOT_DISTRICT=rudraprayag
